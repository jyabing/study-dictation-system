async function loadCurrentQuestion() {
    setLoading(true);
    try {
        const response = await fetch(API_URL, {
            method: "GET",
            headers: {
                "X-Requested-With": "XMLHttpRequest",
            },
            credentials: "same-origin",
        });

        const data = await response.json();

        if (data.empty) {
            const isSuccessEmpty = ["today_done", "all_mastered"].includes(data.reason);
            const kind = isSuccessEmpty ? "success" : "warning";
            const safeMessage = (data.message || "").trim() || "当前没有可训练内容。";
            const emptyNextReviewText =
                (data.next_review_text || data.next_review_display || "").trim() || "未安排";

            let emptyTitleText = "当前没有可训练内容";
            let emptySubtitleText = "根据 API 返回原因显示。";

            if (data.reason === "today_done") {
                emptyTitleText = "今日计划已完成";
                emptySubtitleText = "你今天的训练任务已经全部完成。";
            } else if (data.reason === "all_mastered") {
                emptyTitleText = `${TRAIN_SCOPE_LABEL}已完成本轮严格循环`;
                emptySubtitleText = "当前范围内已经没有需要继续训练的内容。";
            } else {
                emptySubtitleText = "当前没有可继续训练的题目。";
            }

            if (isSuccessEmpty) {
                showCompletedQuestionMode(
                    safeMessage,
                    emptyTitleText,
                    emptySubtitleText,
                    emptyNextReviewText
                );
            } else {
                showEmptyMode(safeMessage, kind, emptyTitleText, emptySubtitleText);
            }

            if (data.reason === "today_done") {
                chipStage.textContent = "当前阶段：今日计划完成";
            } else if (data.reason === "all_mastered") {
                chipStage.textContent = "当前阶段：本轮循环完成";
            } else {
                chipStage.textContent = "当前阶段：暂无可训练内容";
            }

            let nextReviewLabel = `下一次复习：${emptyNextReviewText}`;

            if (
                emptyNextReviewText &&
                emptyNextReviewText !== "未安排" &&
                emptyNextReviewText !== "待安排" &&
                ["today_done", "all_mastered"].includes(data.reason)
            ) {
                nextReviewLabel = `下一次复习：${emptyNextReviewText}（已到期）`;
            }

            chipNextReview.textContent = nextReviewLabel;

            if (data.reason === "today_done") {
                chipStatus.textContent = "当前状态：今日计划已完成";
                chipSource.textContent = "训练来源：今日计划已完成";
            } else if (data.reason === "all_mastered") {
                chipStatus.textContent = `当前状态：${TRAIN_SCOPE_LABEL}已完成本轮严格循环`;
                chipSource.textContent = `训练来源：${TRAIN_SCOPE_LABEL}循环完成`;
            } else {
                chipStatus.textContent = "当前状态：暂无可训练内容";
                chipSource.textContent = "训练来源：暂无可训练内容";
            }

            statMemoryLevel.textContent = "-";
            sideType.textContent = "-";
            sideTrainingId.textContent = "-";
            sideIsTodayPlan.textContent = "-";
            sideCycleStep.textContent = "-";
            sideStepLabel.textContent = "-";
            sideStatusText.textContent = "-";
            sideLastResult.textContent = "-";
            sideNextReview.textContent = "-";
            sideCorrectAnswer.textContent = "提交后显示";
            return;
        }

        renderPayload(data);
    } catch (error) {
        console.error("loadCurrentQuestion failed:", error);

        chipStage.textContent = "当前阶段：加载失败";
        chipNextReview.textContent = "下一次复习：未安排";
        chipStatus.textContent = "当前状态：加载失败";
        chipSource.textContent = "训练来源：请求失败";

        statMemoryLevel.textContent = "-";
        sideType.textContent = "-";
        sideTrainingId.textContent = "-";
        sideIsTodayPlan.textContent = "-";
        sideCycleStep.textContent = "-";
        sideStepLabel.textContent = "-";
        sideStatusText.textContent = "-";
        sideLastResult.textContent = "-";
        sideNextReview.textContent = "-";
        sideCorrectAnswer.textContent = "提交后显示";

        showEmptyMode("加载当前题目失败，请刷新页面重试。", "warning");
    } finally {
        setLoading(false);
    }
}


//
// 手动升一级（前端交互说明）
// =========================
//
// 当前训练页只提供“手动升一级”按钮，不提供手动降级按钮。
//
// 这个按钮的作用不是“宣布永久掌握”，而是：
// 用户主动告诉系统：
// “这条素材当前熟练度高于系统估计，请把当前循环步往前推进 1 步。”
//
// 前端职责：
// 1. 读取当前 training_id
// 2. 调用手动升级接口
// 3. 成功后刷新循环信息展示：
//    - 顶部循环步
//    - 当前阶段
//    - 当前状态
//    - 右侧循环步 / 阶段 / 状态 / 下一次复习
// 4. 显示“已手动升一级”反馈
//
// 重要说明：
// - 手动升一级不等于永久掌握
// - 手动升一级不等于以后不会被打回去
// - 后续如果答错，系统仍会 wrong_reset
// - 后续如果错过允许复习窗口，系统仍会 overdue_reset
//
// 也就是说：
// 手动升一级只是人工上调当前状态，
// 不会绕过后端已有的自动回退规则。
//

async function manualAdjustMemory(action) {
    if (state.loading) {
        return;
    }

    const trainingId = trainingIdInput.value.trim();

    if (!trainingId) {
        setFeedback("当前题目还没有准备好，请先重新加载。", "warning");
        return;
    }

    if (action !== "upgrade") {
        setFeedback("当前仅支持手动升一级。", "warning");
        return;
    }

    const targetUrl = MANUAL_UPGRADE_URL;

    setLoading(true);
    clearFeedback();

    const formData = new URLSearchParams();
    formData.append("training_id", trainingId);

    try {
        const response = await fetch(targetUrl, {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
                "X-CSRFToken": getCookie("csrftoken"),
                "X-Requested-With": "XMLHttpRequest",
            },
            body: formData.toString(),
            credentials: "same-origin",
        });

        const data = await response.json();

        if (!response.ok || data.ok === false) {
            setFeedback(data.error || data.result || "手动调节失败，请重试。", "wrong");
            return;
        }

        applyCyclePanel({
            ...data,
            ...(data.cycle_after || {})
        });

        if (typeof data.memory_level_after !== "undefined" && statMemoryLevel) {
            statMemoryLevel.textContent = String(data.memory_level_after);
        }

        setFeedback(
            data.result || (action === "upgrade" ? "✅ 已手动升一级" : "⚠️ 已手动降一级"),
            action === "upgrade" ? "correct" : "warning"
        );
    } catch (error) {
        setFeedback("手动调节失败，请检查网络或刷新页面后重试。", "wrong");
    } finally {
        setLoading(false);
    }
}

async function submitAnswer(event) {
    event.preventDefault();

    if (state.loading) {
        return;
    }

    const trainingId = trainingIdInput.value.trim();
    const answer = answerInput.value.trim();
    const qType = getQuestionType(state.current || {});

    if (!trainingId) {
        setFeedback("当前题目还没有准备好，请先重新加载。", "warning");
        return;
    }

    const isEmptyAnswer = !answer;

    if (isEmptyAnswer) {
        setFeedback("你还没有填写回答，正在为你请求分段提示...", "warning");
    }

    setLoading(true);
    clearFeedback();

    const duration = Math.max(0, Date.now() - state.startedAt);
    const formData = new URLSearchParams();
    formData.append("training_id", trainingId);
    formData.append("answer", answer);
    formData.append("duration", String(duration));
    formData.append("used_hint", state.usedHint ? "1" : "0");
    formData.append("is_empty_submission", isEmptyAnswer ? "1" : "0");
    formData.append("retry_count", String(state.retryCount));

    try {
        const response = await fetch(API_URL, {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
                "X-CSRFToken": getCookie("csrftoken"),
                "X-Requested-With": "XMLHttpRequest",
            },
            body: formData.toString(),
            credentials: "same-origin",
        });

        const data = await response.json();

        if (!response.ok || data.ok === false) {
            const feedbackType = (data.is_empty_submission || data.is_assist_hint) ? "warning" : "wrong";

            if (data.is_empty_submission && answerInput) {
                answerInput.value = "";
                answerInput.focus();
            } else if (data.is_assist_hint && answerInput) {
                answerInput.focus();
            }

            setFeedback(data.result || "提交失败，请重试。", feedbackType);
            return;
        }

        const resultLevel = data.result_level || (data.is_correct ? "correct" : "wrong");

        let resultType = "wrong";
        if (resultLevel === "normalized" || resultLevel === "reading") {
            resultType = "warning";
        } else if (resultLevel !== "wrong") {
            resultType = "correct";
        }

        let feedbackMessage =
            data.feedback_message
            || data.result
            || (data.is_correct ? "回答正确" : "答案不正确");

        if (!data.is_correct && data.error_tip) {
            feedbackMessage = `${feedbackMessage}\n错因提示：${data.error_tip}`;
        }

        if (data.is_correct && data.used_hint) {
            feedbackMessage = "回答正确，但本次使用了提示";
        } else if (data.is_correct && (data.last_result === "slow_correct" || data.review_result === "slow_correct")) {
            feedbackMessage = "回答正确，但反应偏慢";
        } else if (data.is_correct && Number(data.retry_count || 0) >= 1) {
            const retryCount = Number(data.retry_count || 0);
            feedbackMessage = retryCount === 1
                ? "回答正确，本题重试 1 次后通过"
                : `回答正确，本题重试 ${retryCount} 次后通过`;
        }

        setFeedback(feedbackMessage, resultType);

        const correctAnswersRaw = Array.isArray(data.correct_answers)
            ? data.correct_answers
            : [pickText(data, ["correct_answer", "answer"], "")].filter(Boolean);

        const correctAnswersText = correctAnswersRaw.join(" / ");
        sideCorrectAnswer.textContent = correctAnswersText || "未返回";

        applyCyclePanel({
            ...data,
            ...(data.cycle_after || {})
        });

        submitBtn.disabled = true;
        answerInput.disabled = true;
        reloadBtn.disabled = true;

        if (!data.is_correct) {
            state.retryCount += 1;
            revealChoiceTexts();
            markChoiceResult(false, answer, correctAnswersRaw);
            nextBtn.style.display = "inline-flex";
        } else {
            markChoiceResult(true, answer, correctAnswersRaw);
            nextBtn.style.display = "none";
            playAnswerAudioThenNext(data, 1200);
        }
    } catch (error) {
        setFeedback("提交失败，请检查网络或刷新页面后重试。", "wrong");
    } finally {
        setLoading(false);
    }
}

answerForm.addEventListener("submit", submitAnswer);

if (showHintBtn) {
    showHintBtn.addEventListener("click", () => {
        if (!questionInstruction || !questionInstruction.textContent.trim()) {
            return;
        }

        questionInstruction.style.display = "block";
        state.usedHint = true;
        showHintBtn.textContent = "提示已展开";
        setFeedback("提示短语已展开。", "info");
    });
}

if (manualUpgradeBtn) {
    manualUpgradeBtn.addEventListener("click", () => {
        manualAdjustMemory("upgrade");
    });
}

if (speechUseTextBtn) {
    speechUseTextBtn.addEventListener("click", () => {
        stopSpeechRecognition(true);
        enableSpeechTextFallback();
        setFeedback("已切换到文本输入兜底。", "info");
    });
}

if (speechRetryBtn) {
    speechRetryBtn.addEventListener("click", () => {
        stopSpeechRecognition(true);
        resetSpeechUi();

        if (state.current && isSpeechQuestionType(getQuestionType(state.current))) {
            if (textAnswerWorkspace) {
                textAnswerWorkspace.style.display = "none";
            }

            startSpeechRecognition();
        }
    });
}

if (speechStartBtn) {
    speechStartBtn.addEventListener("click", () => {
        if (!state.current || !isSpeechQuestionType(getQuestionType(state.current))) {
            return;
        }

        startSpeechRecognition();
    });
}

if (speechStopBtn) {
    speechStopBtn.addEventListener("click", () => {
        if (!state.isRecognizing) {
            return;
        }

        if (speechStatus) {
            speechStatus.textContent = "已停止录音，正在结束识别...";
        }

        stopSpeechRecognition(false);
    });
}

nextBtn.addEventListener("click", () => {
    clearAutoNextTimer();
    stopSpeechRecognition(true);
    loadCurrentQuestion();
});

reloadBtn.addEventListener("click", () => {
    clearAutoNextTimer();
    stopSpeechRecognition(true);
    loadCurrentQuestion();
});

loadCurrentQuestion();
</script>
{% endblock %}

{% block extra_js %}
<script>
const TRAIN_SCOPE = "{{ train_scope|default:'lesson' }}";
const TRAIN_SCOPE_LABEL = "{{ train_scope_label|default:'本课训练' }}";
const API_URL = "{% if train_scope == 'book' %}{% url 'book-train-api' book.id %}{% else %}{% url 'lesson-train-api' lesson.id %}{% endif %}";
const MANUAL_UPGRADE_URL = "{% if train_scope == 'book' %}{% url 'book-train-manual-upgrade' book.id %}{% else %}{% url 'lesson-train-manual-upgrade' lesson.id %}{% endif %}";
const questionCard = document.getElementById("question-card");
const emptyCard = document.getElementById("empty-card");
const emptyTitle = document.getElementById("empty-title");
const emptySubtitle = document.getElementById("empty-subtitle");
const emptyMessage = document.getElementById("empty-message");

const chipStage = document.getElementById("chip-stage");
const chipNextReview = document.getElementById("chip-next-review");
const chipStatus = document.getElementById("chip-status");
const chipSource = document.getElementById("chip-source");

const statPlanTotal = document.getElementById("stat-plan-total");
const statPlanDone = document.getElementById("stat-plan-done");
const statPlanProgress = document.getElementById("stat-plan-progress");
const statMemoryLevel = document.getElementById("stat-memory-level");

const questionTypeBadge = document.getElementById("question-type-badge");
const questionInstruction = document.getElementById("question-instruction");
const questionInstructionToggle = document.getElementById("question-instruction-toggle");
const showHintBtn = document.getElementById("show-hint-btn");
const questionPrompt = document.getElementById("question-prompt");
const questionExtra = document.getElementById("question-extra");
const audioWrap = document.getElementById("audio-wrap");
const questionAudio = document.getElementById("question-audio");
const choicesGrid = document.getElementById("choices-grid");

const answerForm = document.getElementById("answer-form");
const trainingIdInput = document.getElementById("training-id");
const answerInput = document.getElementById("answer-input");
const submitBtn = document.getElementById("submit-btn");
const nextBtn = document.getElementById("next-btn");
const reloadBtn = document.getElementById("reload-btn");
const manualUpgradeBtn = document.getElementById("manual-upgrade-btn");
const trainSummaryFold = document.querySelector(".train-summary-fold")
const textAnswerWorkspace = document.getElementById("text-answer-workspace");
const speechWorkspace = document.getElementById("speech-workspace");
const speechModeBadge = document.getElementById("speech-mode-badge");
const speechStatus = document.getElementById("speech-status");
const speechHint = document.getElementById("speech-hint");
const speechStartBtn = document.getElementById("speech-start-btn");
const speechStopBtn = document.getElementById("speech-stop-btn");
const speechRetryBtn = document.getElementById("speech-retry-btn");
const speechUseTextBtn = document.getElementById("speech-use-text-btn");
const speechResultPanel = document.getElementById("speech-result-panel");
const speechResultBox = document.getElementById("speech-result-box");
const speechError = document.getElementById("speech-error");
const feedbackBox = document.getElementById("feedback-box");

const sideType = document.getElementById("side-type");
const sideTrainingId = document.getElementById("side-training-id");
const sideIsTodayPlan = document.getElementById("side-is-today-plan");
const sideCycleStep = document.getElementById("side-cycle-step");
const sideStepLabel = document.getElementById("side-step-label");
const sideStatusText = document.getElementById("side-status-text");
const sideLastResult = document.getElementById("side-last-result");
const sideNextReview = document.getElementById("side-next-review");
const sideCorrectAnswer = document.getElementById("side-correct-answer");

const state = {
    current: null,
    startedAt: 0,
    selectedChoiceIndex: null,
    loading: false,
    autoNextTimer: null,
    inputMode: "text",
    usedHint: false,
    retryCount: 0,
    speechErrorCount: 0,
    recognizedText: "",

    recognition: null,
    recognitionLang: "en-US",
    isRecognizing: false,
    recognitionFinalText: "",
    recognitionInterimText: "",
    recognitionShouldAutoSubmit: false,
    recognitionStoppedManually: false,
    recognitionSessionId: 0,
    pendingRecognitionStart: false,
};

function getCookie(name) {
    const cookieValue = document.cookie
        .split("; ")
        .find(row => row.startsWith(name + "="));
    return cookieValue ? decodeURIComponent(cookieValue.split("=")[1]) : "";
}

function escapeHtml(value) {
    return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
}

function pickText(obj, keys, fallback = "") {
    for (const key of keys) {
        const value = obj?.[key];
        if (value !== undefined && value !== null && String(value).trim() !== "") {
            return String(value);
        }
    }
    return fallback;
}

function formatLastResult(value) {
    const raw = String(value || "").trim();

    if (!raw) {
        return "-";
    }

    const mapping = {
        "correct": "独立答对",
        "hint_correct": "提示后答对",
        "slow_correct": "答对但反应偏慢",
        "mastered": "本轮完成",
        "wrong_reset": "答错重置",
        "overdue_reset": "超窗重置",
        "replay_wrong": "错词复盘未通过",
        "replay_correct": "错词复盘通过",
    };

    return mapping[raw] || raw;
}

function applyCyclePanel(payload) {
    const stepLabel = pickText(
        payload,
        ["step_label", "stage_label", "current_stage_label", "stage"],
        "进行中"
    );

    const nextReviewText = pickText(
        payload,
        ["next_review_text", "next_review_display", "next_review"],
        "未安排"
    );

    const cycleStep = pickText(payload, ["cycle_step", "memory_level"], "0");
    const statusText = pickText(payload, ["status_text"], "进行中");
    const lastResultText = formatLastResult(pickText(payload, ["last_result"], ""));
    const qType = pickText(payload, ["type", "qtype"], sideType?.textContent || "unknown");

    setTextSafe(chipStage, `当前阶段：${stepLabel}`);
    setTextSafe(chipNextReview, `下一次复习：${nextReviewText}`);
    setTextSafe(chipStatus, `当前状态：${statusText}`);
    setTextSafe(
        chipSource,
        `训练来源：${payload.is_today_plan ? "今日计划" : pickText(payload, ["train_scope_label"], TRAIN_SCOPE_LABEL)}`
    );

    setTextSafe(statPlanTotal, pickText(payload, ["plan_total"], statPlanTotal?.textContent || "0"));
    setTextSafe(statPlanDone, pickText(payload, ["plan_done"], statPlanDone?.textContent || "0"));
    setTextSafe(statPlanProgress, `${pickText(payload, ["plan_progress"], "0")}%`);
    setTextSafe(statMemoryLevel, cycleStep);

    setTextSafe(sideType, qType);
    setTextSafe(sideTrainingId, pickText(payload, ["training_id"], trainingIdInput?.value || "-"));
    setTextSafe(sideIsTodayPlan, payload.is_today_plan ? "是" : "否");
    setTextSafe(sideCycleStep, cycleStep);
    setTextSafe(sideStepLabel, stepLabel);
    setTextSafe(sideStatusText, statusText);
    setTextSafe(sideLastResult, lastResultText);
    setTextSafe(sideNextReview, nextReviewText);
}

function getChoiceText(choice, index) {
    return pickText(choice, [
        "text", "label", "value", "content", "answer", "prompt", "display", "title"
    ], `选项 ${index + 1}`);
}

function getChoiceSubmitValue(choice, index) {
    return getChoiceText(choice, index);
}

function getQuestionText(payload) {
    return pickText(payload, [
        "prompt", "question", "title", "text", "stem", "display_text"
    ], "当前题目加载成功，但没有找到可显示的题干。");
}

function getInstructionText(payload) {
    return pickText(payload, [
        "instruction_text", "instruction", "task", "guide", "hint"
    ], "");
}

function getExtraText(payload) {
    return pickText(payload, [
        "cloze_text", "sentence", "explain", "note", "subtitle"
    ], "");
}

function getAudioUrl(payload) {
    return pickText(payload, [
        "resolved_audio", "audio", "audio_url"
    ], "");
}

function getQuestionType(payload) {
    return pickText(payload, [
        "display_item_type", "type", "qtype", "item_type"
    ], "unknown");
}

function isSpeechQuestionType(qType) {
    return qType === "listen_asr" || qType === "speak_read";
}

function resetSpeechUi() {
    state.recognizedText = "";
    state.recognitionFinalText = "";
    state.recognitionInterimText = "";
    state.recognitionShouldAutoSubmit = false;

    if (speechResultPanel) {
        speechResultPanel.style.display = "none";
    }

    if (speechResultBox) {
        speechResultBox.textContent = "暂无识别结果";
    }

    if (speechError) {
        speechError.style.display = "none";
        speechError.textContent = "";
    }

    if (speechStatus) {
        speechStatus.textContent = "等待开始录音";
    }

    if (speechStartBtn) {
        speechStartBtn.style.display = "inline-flex";
    }

    if (speechStopBtn) {
        speechStopBtn.style.display = "none";
    }

    if (speechRetryBtn) {
        speechRetryBtn.style.display = "none";
    }
}

function showTextWorkspace() {
    state.inputMode = "text";

    if (textAnswerWorkspace) {
        textAnswerWorkspace.style.display = "flex";
    }

    if (speechWorkspace) {
        speechWorkspace.style.display = "none";
    }
}

function showSpeechWorkspace(modeLabel, hintText) {
    state.inputMode = "speech";

    if (speechWorkspace) {
        speechWorkspace.style.display = "flex";
    }

    if (textAnswerWorkspace) {
        textAnswerWorkspace.style.display = "none";
    }

    if (speechModeBadge) {
        speechModeBadge.textContent = modeLabel;
    }

    if (speechHint) {
        speechHint.textContent = hintText;
    }

    resetSpeechUi();
}

function enableSpeechTextFallback() {
    state.inputMode = "speech_text_fallback";

    if (speechWorkspace) {
        speechWorkspace.style.display = "flex";
    }

    if (textAnswerWorkspace) {
        textAnswerWorkspace.style.display = "flex";
    }

    if (speechStatus) {
        speechStatus.textContent = "已切换到文本输入";
    }

    if (answerInput) {
        answerInput.disabled = false;
        answerInput.focus();
    }
}

function getSpeechRecognitionCtor() {
    return window.SpeechRecognition || window.webkitSpeechRecognition || null;
}

function hasSpeechRecognitionSupport() {
    return Boolean(getSpeechRecognitionCtor());
}

function showSpeechError(message) {
    if (speechError) {
        speechError.style.display = "block";
        speechError.textContent = message;
    }

    state.speechErrorCount += 1;

    if (speechRetryBtn) {
        speechRetryBtn.style.display = "inline-flex";
    }

    if (state.speechErrorCount >= 2) {
        enableSpeechTextFallback();

        if (speechStatus) {
            speechStatus.textContent = "语音识别不稳定，已自动切换到文本输入";
        }
    }
}

function clearSpeechError() {
    if (speechError) {
        speechError.style.display = "none";
        speechError.textContent = "";
    }
}

function updateSpeechResult(finalText = "", interimText = "") {
    if (!speechResultPanel || !speechResultBox) {
        return;
    }

    const finalClean = String(finalText || "").trim();
    const interimClean = String(interimText || "").trim();

    if (!finalClean && !interimClean) {
        speechResultPanel.style.display = "none";
        speechResultBox.textContent = "暂无识别结果";
        return;
    }

    speechResultPanel.style.display = "flex";

    if (finalClean && interimClean) {
        speechResultBox.innerHTML = `
            <div>最终结果：${escapeHtml(finalClean)}</div>
            <div style="margin-top:8px;color:var(--text-soft);">识别中：${escapeHtml(interimClean)}</div>
        `;
        return;
    }

    if (finalClean) {
        speechResultBox.textContent = finalClean;
        return;
    }

    speechResultBox.innerHTML = `<span style="color:var(--text-soft);">识别中：${escapeHtml(interimClean)}</span>`;
}

function submitRecognizedAnswer() {
    const finalText = String(state.recognitionFinalText || "").trim();
    const interimText = String(state.recognitionInterimText || "").trim();
    const bestText = finalText || interimText;

    if (!bestText) {
        showSpeechError("没有得到可用的识别结果，请重新录音或改用文本输入。");
        return;
    }

    state.recognizedText = bestText;
    answerInput.value = bestText;

    if (speechStatus) {
        speechStatus.textContent = "识别完成，正在提交...";
    }

    if (typeof answerForm.requestSubmit === "function") {
        answerForm.requestSubmit();
    } else {
        answerForm.dispatchEvent(new Event("submit", { bubbles: true, cancelable: true }));
    }
}

function stopSpeechRecognition(cancelSubmit = false) {
    if (!state.recognition) {
        return;
    }

    state.recognitionStoppedManually = true;

    if (cancelSubmit) {
        state.recognitionShouldAutoSubmit = false;
    }

    try {
        state.recognition.stop();
    } catch (error) {
        console.warn("stop recognition failed:", error);
    }
}

function startSpeechRecognition() {
    if (!state.current || !isSpeechQuestionType(getQuestionType(state.current))) {
        return;
    }

    const RecognitionCtor = getSpeechRecognitionCtor();

    if (!RecognitionCtor) {
        enableSpeechTextFallback();
        showSpeechError("当前浏览器不支持 SpeechRecognition / webkitSpeechRecognition，已切换到文本输入。");
        return;
    }

    if (state.isRecognizing || state.pendingRecognitionStart) {
        return;
    }

    clearFeedback();
    clearSpeechError();

    state.recognitionFinalText = "";
    state.recognitionInterimText = "";
    state.recognitionShouldAutoSubmit = true;
    state.recognitionStoppedManually = false;
    state.pendingRecognitionStart = true;
    state.speechErrorCount = 0;
    state.recognitionSessionId += 1;

    const sessionId = state.recognitionSessionId;

    updateSpeechResult("", "");

    const recognition = new RecognitionCtor();
    recognition.lang = state.recognitionLang || "en-US";
    recognition.continuous = false;
    recognition.interimResults = true;
    recognition.maxAlternatives = 1;

    state.recognition = recognition;

    recognition.onstart = () => {
        if (sessionId !== state.recognitionSessionId) {
            try {
                recognition.stop();
            } catch (error) {
                console.warn("stale recognition stop failed:", error);
            }
            return;
        }

        state.pendingRecognitionStart = false;
        state.isRecognizing = true;

        if (speechStatus) {
            speechStatus.textContent = "录音中，请开始说话...";
        }

        if (speechStartBtn) {
            speechStartBtn.style.display = "none";
        }

        if (speechStopBtn) {
            speechStopBtn.style.display = "inline-flex";
        }

        if (speechRetryBtn) {
            speechRetryBtn.style.display = "none";
        }
    };

    recognition.onresult = (event) => {
        if (sessionId !== state.recognitionSessionId) {
            return;
        }

        let finalText = state.recognitionFinalText || "";
        let interimText = "";

        for (let i = event.resultIndex; i < event.results.length; i += 1) {
            const transcript = String(event.results[i][0]?.transcript || "").trim();

            if (!transcript) {
                continue;
            }

            if (event.results[i].isFinal) {
                finalText = `${finalText} ${transcript}`.trim();
            } else {
                interimText = `${interimText} ${transcript}`.trim();
            }
        }

        state.recognitionFinalText = finalText.trim();
        state.recognitionInterimText = interimText.trim();

        updateSpeechResult(state.recognitionFinalText, state.recognitionInterimText);

        const merged = (state.recognitionFinalText || state.recognitionInterimText || "").trim();
        if (merged) {
            answerInput.value = merged;
        }

        if (speechStatus) {
            speechStatus.textContent = state.recognitionFinalText
                ? "已识别到可用文本，停止后将自动提交。"
                : "识别中...";
        }
    };

    recognition.onerror = (event) => {
        if (sessionId !== state.recognitionSessionId) {
            return;
        }

        state.pendingRecognitionStart = false;

        const code = String(event.error || "");

        if (code === "aborted" && state.recognitionStoppedManually) {
            return;
        }

        const hasAnyText = Boolean(
            String(state.recognitionFinalText || "").trim() ||
            String(state.recognitionInterimText || "").trim()
        );

        if ((code === "no-speech" || code === "aborted") && hasAnyText) {
            return;
        }

        state.recognitionShouldAutoSubmit = false;

        const mapping = {
            "no-speech": "没有检测到清晰语音，请靠近麦克风后重新录音。",
            "audio-capture": "没有检测到可用麦克风，请检查设备。",
            "not-allowed": "麦克风权限被拒绝，请允许浏览器访问麦克风。",
            "service-not-allowed": "当前环境不允许语音识别服务，请改用文本输入。",
            "network": "语音识别网络异常，请稍后重试或改用文本输入。",
            "aborted": "录音被中断，请重新录音。",
        };

        if (speechStatus) {
            speechStatus.textContent = "识别失败";
        }

        showSpeechError(mapping[code] || `语音识别失败：${code || "未知错误"}`);
    };

    recognition.onend = () => {
        if (sessionId !== state.recognitionSessionId) {
            return;
        }

        const shouldAutoSubmit = state.recognitionShouldAutoSubmit;
        const stoppedManually = state.recognitionStoppedManually;
        const finalText = String(state.recognitionFinalText || "").trim();
        const interimText = String(state.recognitionInterimText || "").trim();
        const bestText = finalText || interimText;

        state.isRecognizing = false;
        state.pendingRecognitionStart = false;
        state.recognition = null;
        state.recognitionStoppedManually = false;

        if (speechStartBtn) {
            speechStartBtn.style.display = "inline-flex";
        }

        if (speechStopBtn) {
            speechStopBtn.style.display = "none";
        }

        if (speechRetryBtn) {
            speechRetryBtn.style.display = "inline-flex";
        }

        if (bestText) {
            if (speechStatus) {
                speechStatus.textContent = shouldAutoSubmit
                    ? "识别完成，正在提交..."
                    : "识别完成";
            }

            if (shouldAutoSubmit && state.inputMode === "speech" && !state.loading) {
                submitRecognizedAnswer();
            }

            return;
        }

        if (speechStatus) {
            speechStatus.textContent = stoppedManually
                ? "已停止录音"
                : "未识别到可用文本";
        }

        if (!stoppedManually) {
            showSpeechError("没有得到可用的识别结果，请重新录音或改用文本输入。");
        }
    };

    try {
        recognition.start();
    } catch (error) {
        state.recognition = null;
        state.isRecognizing = false;
        state.pendingRecognitionStart = false;
        state.recognitionShouldAutoSubmit = false;

        showSpeechError("无法启动麦克风，请检查浏览器权限后重试。");
    }
}

function applyQuestionInputMode(payload) {
    const qType = getQuestionType(payload);
    const instructionText = getInstructionText(payload);
    const questionText = getQuestionText(payload);
    const extra = getExtraText(payload);
    const audioUrl = getAudioUrl(payload);

    state.recognitionLang = pickText(payload, ["asr_lang"], "en-US");

    stopSpeechRecognition(true);
    renderChoices(payload.choices || []);

    state.usedHint = false;
    state.retryCount = 0;

    if (instructionText) {
        if (questionInstructionToggle) {
            questionInstructionToggle.style.display = "flex";
        }

        questionInstruction.style.display = "none";
        questionInstruction.textContent = `提示短语：${instructionText}`;


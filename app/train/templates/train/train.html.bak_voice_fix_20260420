{% extends "train/base_train.html" %}

{% block title %}{{ train_title }} - 训练{% endblock %}

{% block content %}
<div class="page train-page">
    <div class="shell train-shell">

        {% include "train/includes/page_head.html" with head_type="train" head_actions=head_actions head_actions_collapsed=True head_actions_title="页面操作" head_title=train_title head_meta=head_meta head_chips=head_chips %}

        <div class="layout-main">
            <div class="main-left">

                <section class="question-card question-card-priority" id="question-card">
                    <div class="question-header">
                        <div>
                            <h2 class="question-title">当前题目</h2>
                            <div class="question-subtitle">直接开始做题。训练内容优先显示。</div>
                        </div>
                    </div>

                    <div class="question-body">
                        <div class="question-prompt-wrap">
                            <div class="question-type-badge" id="question-type-badge">加载中</div>

                            <div class="question-instruction-toggle" id="question-instruction-toggle" style="display:none;">
                                <button type="button" class="ghost-btn" id="show-hint-btn">查看提示</button>
                            </div>

                            <div class="question-instruction" id="question-instruction" style="display:none;"></div>

                            <div class="question-prompt" id="question-prompt">正在加载当前题目...</div>

                            <div class="question-extra" id="question-extra" style="display:none;"></div>

                            <div class="audio-wrap" id="audio-wrap" style="display:none;">
                                <audio id="question-audio" class="audio-player" controls></audio>
                            </div>

                            <div class="choices-grid" id="choices-grid" style="display:none;"></div>

                            <form class="answer-form" id="answer-form">
                                <input type="hidden" id="training-id" value="">

                                <div class="speech-workspace" id="speech-workspace" style="display:none;">
                                    <div class="speech-mode-bar">
                                        <div class="speech-mode-badge" id="speech-mode-badge">语音训练</div>
                                        <div class="speech-status" id="speech-status">等待开始录音</div>
                                    </div>

                                    <div class="speech-hint" id="speech-hint">
                                        当前题型将优先使用麦克风识别。若识别失败，可回退到文本输入。
                                    </div>

                                    <div class="speech-controls">
                                        <button type="button" class="primary-btn" id="speech-start-btn">开始录音</button>
                                        <button type="button" class="secondary-btn" id="speech-stop-btn" style="display:none;">停止录音</button>
                                        <button type="button" class="ghost-btn" id="speech-retry-btn" style="display:none;">重新录音</button>
                                        <button type="button" class="ghost-btn" id="speech-use-text-btn">改用文本输入</button>
                                    </div>

                                    <div class="speech-result-panel" id="speech-result-panel" style="display:none;">
                                        <div class="speech-result-label">识别结果</div>
                                        <div class="speech-result-box" id="speech-result-box">暂无识别结果</div>
                                    </div>

                                    <div class="speech-error" id="speech-error" style="display:none;"></div>
                                </div>

                                <div class="text-answer-workspace" id="text-answer-workspace">
                                    <input
                                        type="text"
                                        id="answer-input"
                                        class="answer-input"
                                        placeholder="请输入回答，然后提交"
                                        autocomplete="off"
                                    >
                                </div>

                                <div class="answer-actions">
                                    <button type="submit" class="primary-btn" id="submit-btn">提交回答</button>
                                    <button type="button" class="secondary-btn" id="next-btn" style="display:none;">下一题</button>
                                    <button type="button" class="ghost-btn" id="reload-btn">重新加载当前题</button>
                                </div>

                                <div class="memory-actions-card" id="memory-actions-card">
                                    <div class="memory-actions-title">记忆调节</div>

                                    <div class="memory-actions-grid">
                                        <button type="button" class="memory-action-btn memory-action-btn-up" id="manual-upgrade-btn">
                                            手动升一级
                                        </button>
                                    </div>

                                    <div class="memory-actions-note">
                                        这里只是手动调整当前循环步。之后如果答错或错过复习窗口，仍会按系统规则自动回退/重置。
                                    </div>
                                </div>

                            </form>

                            <div class="feedback-box info" id="feedback-box"></div>
                        </div>
                    </div>
                </section>

                <section class="train-status-bar" aria-label="训练状态">
                    <div class="train-status-item">
                        <span class="train-status-label">计划</span>
                        <span class="train-status-value" id="stat-plan-total">{{ plan_total|default:0 }}</span>
                    </div>

                    <div class="train-status-divider">｜</div>

                    <div class="train-status-item">
                        <span class="train-status-label">已完成</span>
                        <span class="train-status-value" id="stat-plan-done">{{ plan_done|default:0 }}</span>
                    </div>

                    <div class="train-status-divider">｜</div>

                    <div class="train-status-item">
                        <span class="train-status-label">进度</span>
                        <span class="train-status-value" id="stat-plan-progress">{{ plan_progress|default:0 }}%</span>
                    </div>

                    <div class="train-status-divider">｜</div>

                    <div class="train-status-item">
                        <span class="train-status-label">循环步</span>
                        <span class="train-status-value" id="stat-memory-level">-</span>
                    </div>
                </section>

                <section class="empty-card" id="empty-card">
                    <div class="empty-header">
                        <div>
                            <h2 class="empty-title" id="empty-title">当前没有可训练内容</h2>
                            <div class="empty-subtitle" id="empty-subtitle">根据 API 返回原因显示。</div>
                        </div>
                    </div>

                    <div class="empty-body">
                        <div class="empty-message" id="empty-message"></div>
                    </div>
                </section>
            </div>

            <div class="main-right">
                <details class="train-fold train-summary-fold">
                    <summary class="train-fold-summary">
                        <span class="train-fold-title">当前训练摘要</span>
                        <span class="train-fold-hint">点击展开</span>
                    </summary>

                    <div class="train-fold-body">
                        <div class="side-list cycle-side-list">
                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">训练类型</div>
                                <div class="side-row-value" id="side-type">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">当前题 ID</div>
                                <div class="side-row-value" id="side-training-id">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">是否今日计划</div>
                                <div class="side-row-value" id="side-is-today-plan">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">循环步</div>
                                <div class="side-row-value" id="side-cycle-step">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">当前阶段</div>
                                <div class="side-row-value" id="side-step-label">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">当前状态</div>
                                <div class="side-row-value" id="side-status-text">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">结果标记</div>
                                <div class="side-row-value" id="side-last-result">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">下一次复习</div>
                                <div class="side-row-value" id="side-next-review">-</div>
                            </div>

                            <div class="side-row cycle-side-row">
                                <div class="side-row-label">目标回答</div>
                                <div class="side-row-value" id="side-correct-answer">提交后显示</div>
                            </div>
                        </div>
                    </div>
                </details>
            </div>
        </div>

        <div class="footer-note">{{ train_scope_label }} Page</div>
    </div>
</div>
{% endblock %}

{% block extra_css %}


<style>
.train-page {
    --max-width: 1440px;
}

.train-shell {
    gap: 10px;
}

/* =========================
   通用卡片
   ========================= */
.question-card,
.side-card,
.empty-card,
.train-status-bar,
.train-fold {
    background: linear-gradient(180deg, var(--panel), var(--panel-2));
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    overflow: hidden;
}

/* =========================
   主布局
   ========================= */
.layout-main {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.72fr);
    gap: 10px;
    align-items: start;
}

.main-left,
.main-right {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 0;
}

/* =========================
   当前题目卡
   ========================= */
.question-card,
.question-card-priority {
    border-radius: 18px;
    margin: 0;
}

.question-header,
.empty-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
    flex-wrap: wrap;
}

.question-title,
.empty-title {
    margin: 0;
    font-size: 16px;
    font-weight: 900;
    letter-spacing: -0.01em;
    color: var(--text);
}

.question-subtitle {
    display: none !important;
}

.empty-subtitle {
    display: block;
    margin-top: 4px;
    font-size: 13px;
    font-weight: 700;
    color: var(--text-soft);
}

.question-body,
.empty-body {
    padding: 16px;
}

.question-prompt-wrap {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.question-type-badge {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 900;
    border: 1px solid rgba(110, 168, 255, 0.30);
    background: rgba(110, 168, 255, 0.16);
    color: #244a86;
}

.question-instruction {
    align-self: flex-start;
    padding: 8px 12px;
    border-radius: 12px;
    background: rgba(87, 154, 255, 0.10);
    border: 1px solid rgba(87, 154, 255, 0.18);
    color: #4c5f7f;
    font-size: 13px;
    font-weight: 800;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
}

.question-prompt,
.question-card-priority .question-prompt {
    font-size: 34px !important;
    line-height: 1.16 !important;
    font-weight: 900 !important;
    letter-spacing: -0.02em;
    color: var(--text);
    word-break: break-word;
    margin: 0;
}

.question-extra {
    padding: 12px 14px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: #4c5f7f;
    font-size: 13px;
    white-space: pre-wrap;
    word-break: break-word;
}

.audio-wrap {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.audio-player {
    width: 100%;
}

/* =========================
   选项区
   ========================= */
.choices-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
}

.choice-btn {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    width: 100%;
    min-height: 88px;
    padding: 12px 14px;
    text-align: left;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    transition: var(--transition);
}

.choice-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--border-strong);
    transform: translateY(-1px);
}

.choice-btn.selected {
    background: rgba(110, 168, 255, 0.14);
    border-color: rgba(110, 168, 255, 0.34);
    box-shadow: 0 10px 24px rgba(79, 141, 255, 0.20);
}

.choice-btn.correct {
    border-color: rgba(51, 209, 122, 0.30);
    background: rgba(51, 209, 122, 0.10);
}

.choice-btn.wrong {
    border-color: rgba(255, 114, 114, 0.30);
    background: rgba(255, 114, 114, 0.10);
}

.choice-head {
    display: flex;
    align-items: center;
    gap: 12px;
}

.choice-key {
    width: 34px;
    min-width: 34px;
    height: 34px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 900;
    color: var(--text);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.10);
}

.choice-play-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 12px;
    border-radius: 10px;
    border: 1px solid rgba(110, 168, 255, 0.30);
    background: rgba(110, 168, 255, 0.16);
    color: #244a86;
    font-size: 13px;
    font-weight: 900;
    transition: var(--transition);
}

.choice-play-btn:hover {
    background: rgba(110, 168, 255, 0.22);
    border-color: rgba(110, 168, 255, 0.38);
}

.choice-text {
    display: none;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 800;
    word-break: break-word;
    color: var(--text);
    padding-top: 2px;
}

.choice-text.show {
    display: block;
}

.choice-text-label {
    font-size: 11px;
    color: #6a7a95;
    font-weight: 700;
    margin-bottom: 6px;
}

/* =========================
   作答区
   ========================= */
.answer-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.answer-input {
    width: 100%;
    min-height: 52px;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
    outline: none;
    transition: var(--transition);
    font-size: 16px;
}

.answer-input::placeholder {
    color: var(--text-faint);
}

.answer-input:focus {
    border-color: rgba(110, 168, 255, 0.40);
    background: rgba(255, 255, 255, 0.07);
    box-shadow: 0 0 0 4px rgba(110, 168, 255, 0.12);
}

.question-instruction-toggle {
    display: flex;
    justify-content: flex-start;
    margin: 6px 0 8px;
}

.question-instruction-toggle .ghost-btn {
    min-height: 34px;
    padding: 0 12px;
}

.question-instruction {
    margin-bottom: 10px;
}

.text-answer-workspace {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.memory-actions-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
}

.memory-actions-title {
    font-size: 12px;
    font-weight: 900;
    color: var(--text);
    letter-spacing: 0.02em;
}

.memory-actions-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 10px;
}

.memory-action-btn {
    min-height: 42px;
    padding: 0 14px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.10);
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.15s ease, opacity 0.15s ease, border-color 0.15s ease;
}

.memory-action-btn:hover {
    transform: translateY(-1px);
}

.memory-action-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
    transform: none;
}

.memory-action-btn-up {
    color: #1f5f37;
    background: rgba(122, 214, 163, 0.18);
    border-color: rgba(122, 214, 163, 0.30);
}

.memory-action-btn-down {
    color: #8a5a18;
    background: rgba(255, 196, 102, 0.18);
    border-color: rgba(255, 196, 102, 0.30);
}

.memory-actions-note {
    font-size: 11px;
    line-height: 1.6;
    color: var(--text-faint);
}


.speech-workspace {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px;
    border-radius: 16px;
    border: 1px solid rgba(110, 168, 255, 0.18);
    background: rgba(110, 168, 255, 0.06);
}

.speech-mode-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.speech-mode-badge {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 900;
    color: #244a86;
    border: 1px solid rgba(110, 168, 255, 0.30);
    background: rgba(110, 168, 255, 0.16);
}

.speech-status {
    font-size: 12px;
    font-weight: 800;
    color: #4c5f7f;
}
.speech-hint {
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: #4c5f7f;
    font-size: 12px;
    line-height: 1.6;
}

.speech-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.speech-result-panel {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.speech-result-label {
    font-size: 11px;
    font-weight: 800;
    color: var(--text-faint);
    letter-spacing: 0.02em;
}

.speech-result-box {
    min-height: 64px;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.05);
    color: var(--text);
    font-size: 14px;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
}

.speech-error {
    padding: 10px 12px;
    border-radius: 12px;
    border: 1px solid rgba(255, 114, 114, 0.30);
    background: rgba(255, 114, 114, 0.16);
    color: #8a2f2f;
    font-size: 12px;
    font-weight: 800;
    line-height: 1.5;
}

.answer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
}

.answer-actions .primary-btn {
    min-height: 48px !important;
    font-size: 15px !important;
    font-weight: 800 !important;
}

.answer-actions .secondary-btn,
.answer-actions .ghost-btn {
    min-height: 40px !important;
    font-size: 14px !important;
}

/* =========================
   反馈区
   ========================= */
.feedback-box {
    display: none;
    padding: 14px 16px;
    border-radius: 16px;
    font-size: 13px;
    font-weight: 800;
    line-height: 1.5;
    border: 1px solid var(--border);
}

.feedback-box.show {
    display: block;
}

.feedback-box.correct {
    background: rgba(51, 209, 122, 0.16);
    border-color: rgba(51, 209, 122, 0.30);
    color: #1f6b43;
}

.feedback-box.wrong {
    background: rgba(255, 114, 114, 0.16);
    border-color: rgba(255, 114, 114, 0.30);
    color: #8a2f2f;
}

.feedback-box.info {
    background: rgba(110, 168, 255, 0.16);
    border-color: rgba(110, 168, 255, 0.30);
    color: #244a86;
}

.feedback-box.warning {
    background: rgba(255, 190, 85, 0.16);
    border-color: rgba(255, 190, 85, 0.30);
    color: #8a5a00;
}

/* =========================
   训练状态条（替代四张卡）
   ========================= */
.train-status-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    padding: 8px 10px;
    border-radius: 12px;
    box-shadow: none;
}

.train-status-item {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
}

.train-status-label {
    font-size: 10px;
    line-height: 1.2;
    color: var(--text-soft);
    font-weight: 700;
}

.train-status-value {
    font-size: 14px;
    line-height: 1;
    color: var(--text);
    font-weight: 900;
}

.train-status-divider {
    font-size: 10px;
    line-height: 1;
    color: var(--text-faint);
    opacity: 0.7;
}

/* 强制隐藏旧统计卡残留 */
.stats-grid,
.stats-grid-compact,
.stat-card,
.stat-title,
.stat-value,
.stat-sub {
    display: none !important;
}

/* =========================
   摘要折叠
   ========================= */
.train-fold {
    border-radius: 10px;
    box-shadow: none;
}

.train-fold-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px 10px;
}

.train-fold-summary::-webkit-details-marker {
    display: none;
}

.train-fold-title {
    font-size: 12px;
    font-weight: 800;
    color: var(--text);
}

.train-fold-hint {
    font-size: 9px;
    color: var(--text-faint);
}

.train-fold-body {
    padding: 0 10px 10px;
}

.train-fold .cycle-side-list {
    display: grid;
    gap: 8px;
}

.train-fold .cycle-side-row {
    display: block;
    padding: 10px 12px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
}

.train-fold .cycle-side-row .side-row-label,
.train-fold .cycle-side-row .side-row-value {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
}

.train-fold .cycle-side-row .side-row-label {
    margin-bottom: 4px;
    font-size: 11px;

function markChoiceResult(isCorrect, submittedAnswer, correctAnswers) {
    const buttons = [...choicesGrid.querySelectorAll(".choice-btn")];
    const submitted = (submittedAnswer || "").trim().toLowerCase();
    const correctList = Array.isArray(correctAnswers)
        ? correctAnswers.map(x => String(x).trim().toLowerCase())
        : [];

    buttons.forEach(button => {
        const text = (button.dataset.choiceText || "").trim().toLowerCase();

        if (correctList.includes(text)) {
            button.classList.add("correct");
        }

        if (submitted && text === submitted && !isCorrect) {
            button.classList.add("wrong");
        }
    });
}


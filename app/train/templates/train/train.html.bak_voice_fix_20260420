function renderChoices(choices) {
    choicesGrid.innerHTML = "";
    state.selectedChoiceIndex = null;

    if (!Array.isArray(choices) || choices.length === 0) {
        choicesGrid.style.display = "none";
        return;
    }

    choicesGrid.style.display = "grid";

    choices.forEach((choice, index) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className = "choice-btn";
        button.dataset.index = String(index);
        button.dataset.choiceText = getChoiceText(choice, index);
        button.dataset.submitValue = getChoiceSubmitValue(choice, index);

        const head = document.createElement("div");
        head.className = "choice-head";

        const key = document.createElement("div");
        key.className = "choice-key";
        key.textContent = choice.key || String.fromCharCode(65 + index);

        head.appendChild(key);

        const playableAudio = pickText(choice, [
            "resolved_audio",
            "audio",
            "audio_url"
        ], "");

        if (choice.type === "audio" || playableAudio) {
            const playBtn = document.createElement("button");
            playBtn.type = "button";
            playBtn.className = "choice-play-btn";
            playBtn.textContent = "▶ 播放选项";

            playBtn.addEventListener("click", (event) => {
                event.stopPropagation();

                if (playableAudio) {
                    const audio = new Audio(playableAudio);
                    audio.play().catch(() => {});
                }
            });

            head.appendChild(playBtn);
        } else {
            const fallbackText = document.createElement("div");
            fallbackText.style.fontSize = "15px";
            fallbackText.style.fontWeight = "800";
            fallbackText.style.wordBreak = "break-word";
            fallbackText.textContent = getChoiceText(choice, index);
            head.appendChild(fallbackText);
        }

        const textWrap = document.createElement("div");
        textWrap.className = "choice-text";
        textWrap.innerHTML = `
            <div class="choice-text-label">选项文字</div>
            <div>${escapeHtml(getChoiceText(choice, index))}</div>
        `;

        button.appendChild(head);
        button.appendChild(textWrap);

        button.addEventListener("click", () => {
            [...choicesGrid.querySelectorAll(".choice-btn")].forEach(btn => {
                btn.classList.remove("selected");
            });

            button.classList.add("selected");
            state.selectedChoiceIndex = index;
            answerInput.value = button.dataset.submitValue;

            console.log("choice clicked:", {
                key: choice.key || String.fromCharCode(65 + index),
                choiceText: button.dataset.choiceText,
                submitValue: button.dataset.submitValue
            });
        });

        choicesGrid.appendChild(button);
    });
}

function revealChoiceTexts() {

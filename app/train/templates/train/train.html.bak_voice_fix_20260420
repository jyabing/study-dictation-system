        }
    } else {
        if (questionInstructionToggle) {
            questionInstructionToggle.style.display = "none";
        }

        questionInstruction.style.display = "none";
        questionInstruction.textContent = "";
    }

    if (qType === "listen_asr") {
        questionTypeBadge.textContent = "类型：listen_asr";

        if (extra) {
            questionExtra.style.display = "block";
            questionExtra.textContent = extra;
        } else {
            questionExtra.style.display = "none";

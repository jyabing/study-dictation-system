            questionExtra.style.display = "block";
            questionExtra.textContent = "当前题目没有可播放音频。请根据提示短语和上面的题干直接作答，建议点击“改用文本输入”。";
        }

        if (audioUrl) {
            showSpeechWorkspace(
                "说：根据提示作答",
                "请先播放题干音频，再根据提示短语口头作答。识别失败可改用文本输入。"
            );

            answerInput.value = "";
            answerInput.placeholder = "点击“改用文本输入”后，可手动输入你的回答";
        } else {
            showTextWorkspace();

            answerInput.value = "";
            answerInput.placeholder = "当前没有音频，请根据提示短语和题干直接输入你的回答";
        }

        return;
    }

    if (qType === "speak_read") {
        questionTypeBadge.textContent = "类型：speak_read";
        questionPrompt.textContent = questionText;

        if (extra) {
            questionExtra.style.display = "block";
            questionExtra.textContent = extra;
        } else {
            questionExtra.style.display = "none";
            questionExtra.textContent = "";
        }

        audioWrap.style.display = "none";
        questionAudio.removeAttribute("src");
        questionAudio.load();

        showSpeechWorkspace(
            "说：根据提示作答",
            "请根据提示短语和题干口头作答。识别失败可改用文本输入。"
        );

        if (!hasSpeechRecognitionSupport()) {
            enableSpeechTextFallback();
            showSpeechError("当前浏览器不支持 SpeechRecognition / webkitSpeechRecognition，请改用文本输入。");
        }

        answerInput.value = "";
        answerInput.placeholder = "点击“改用文本输入”后，可手动输入你要说出的回答";
        return;
    }

    showTextWorkspace();

    questionTypeBadge.textContent = `类型：${qType}`;
    questionPrompt.textContent = questionText;

    if (extra) {
